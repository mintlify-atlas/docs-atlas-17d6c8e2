  "keyFeatures": [
    "Multi-role system: client, seller, and admin with protected routes",
    "Product catalog with filters, sorting, and price range",
    "Full shopping flow: cart, checkout, payment, and order confirmation",
    "Client dashboard with order tracking, wishlist, project calculator, and support tickets",
    "Seller dashboard for product management, order fulfillment, and stock alerts",
    "Admin dashboard with user management, inventory control, vendor moderation, and analytics",
    "Dark mode support via Tailwind CSS class strategy",
    "JWT-based authentication with Java Spring Boot backend",
    "PostgreSQL database with SHA-256 password hashing",
    "Animations with Framer Motion and responsive design with Tailwind CSS"
  ],
  "publicApiSurface": [
